# Environment Variables — Smart Pantry Tracker Backend
# Copy this file to .env and fill in your values

# ─── Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/smart_pantry_tracker
# For Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/smart_pantry_tracker

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────
CLIENT_URL=http://localhost:3000
